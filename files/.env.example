# Copy this file's contents into Vercel's Environment Variables settings.
# Do not commit a real .env file with actual secrets to git.

# Your Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# A shared passphrase your staff will use to unlock the New Draft and
# Outcomes Log tabs. Optional — if you leave this unset, those tabs are
# open to anyone with the link, no login at all. Set it if you want even a
# lightweight gate; make it something you can share verbally with staff and
# rotate if someone leaves the practice. Patients never need this either way.
APP_PASSWORD=choose-a-shared-passphrase

# KV_REST_API_URL, KV_REST_API_TOKEN, and related KV_* variables are added
# automatically by Vercel when you connect a Vercel KV database to this
# project. You do not set those manually. See README.md step 3.
